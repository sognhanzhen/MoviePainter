{
  "name": "moviepainter",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "clean:sidecars": "node scripts/clean-sidecars.mjs",
    "dev": "npm run clean:sidecars && next dev --hostname 0.0.0.0 --port 3000",
    "build": "npm run clean:sidecars && npm run typecheck && next build",
    "start": "next start -H 0.0.0.0 -p 3000",
    "typecheck": "tsc --noEmit --incremental false",
    "verify:i18n": "tsx scripts/verify-i18n.mts",
    "verify:prompts": "node scripts/verify-prompt-presets.mjs",
    "verify:draw-option-prompts": "tsx scripts/verify-ai-draw-option-prompts.mjs",
    "verify:draw-prompt-builder": "tsx scripts/verify-ai-draw-prompt-builder.mjs",
    "export:prompt-csv": "tsx scripts/export-prompt-presets-csv.ts",
    "export:draw-option-prompts": "tsx scripts/export-ai-draw-option-prompts-csv.ts",
    "db:init": "npm run db:init --workspace server"
  },
  "dependencies": {
    "next": "^15.3.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.4",
    "concurrently": "^9.2.1"
  },
  "engines": {
    "node": "22.x"
  }
}
