{
  "name": "moviepainter",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "clean:sidecars": "COPYFILE_DISABLE=1 node scripts/clean-sidecars.mjs",
    "dev": "npm run clean:sidecars && rm -rf .next && COPYFILE_DISABLE=1 next dev --hostname 0.0.0.0 --port 3000",
    "build": "npm run clean:sidecars && npm run typecheck && rm -rf .next && COPYFILE_DISABLE=1 next build",
    "start": "COPYFILE_DISABLE=1 next start -H 0.0.0.0 -p ${PORT:-3000}",
    "typecheck": "tsc --noEmit --incremental false",
    "db:init": "npm run db:init --workspace server"
  },
  "dependencies": {
    "next": "^15.3.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.4",
    "concurrently": "^9.2.1"
  }
}
